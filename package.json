{
  "name": "gamzaissac",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native --host 127.0.0.1",
    "build": "tsc --noEmit && vite build --configLoader native",
    "preview": "vite preview --configLoader native --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run test && npm run format:check && npm run build"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
